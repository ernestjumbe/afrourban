FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* ./

RUN npm ci

COPY . .

EXPOSE 3030

HEALTHCHECK --interval=30s --timeout=10s --retries=3 CMD wget -qO- "http://127.0.0.1:${FRONTEND_PORT:-3030}/" >/dev/null 2>&1 || exit 1

CMD ["sh", "-lc", "npm run dev -- --hostname 0.0.0.0 --port ${FRONTEND_PORT:-3030}"]